---
import Layout from '../layouts/Layout.astro';
---

<Layout title="NEWFIT — Tu Gimnasio de Confianza" description="Entrena con nosotros. Instalaciones premium, equipamiento de última generación y entrenadores profesionales. Descubre nuestras tarifas.">

  <!-- NAVBAR -->
  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="#hero" class="navbar-logo">NEW<em>FIT</em></a>
      <button class="theme-switch" id="theme-switch" aria-label="Cambiar tema de color" title="Cambiar tema">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
      <ul class="navbar-links" id="nav-links">
        <li><a href="#hero">Inicio</a></li>
        <li><a href="#tarifas">Tarifas</a></li>
        <li><a href="#galeria">Galería</a></li>
        <li><a href="#contacto">Contacto</a></li>
        <li><a href="#contacto" class="navbar-cta">Únete Ya</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Abrir menú de navegación">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <img src="/images/hero-bg.png" alt="Interior del gimnasio con equipamiento profesional" width="1920" height="1080" loading="eager" />
    </div>
    <div class="hero-content">
      <div class="hero-badge">Entrena · Transforma · Supera</div>
      <h1>
        Supera tus
        <span class="highlight">Límites</span>
      </h1>
      <p class="hero-subtitle">
        Instalaciones de última generación, entrenadores profesionales y una comunidad que te impulsará a alcanzar tus metas.
      </p>
      <div class="hero-buttons">
        <a href="#tarifas" class="btn-primary">Ver Tarifas</a>
        <a href="#contacto" class="btn-outline">Contáctanos</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- TARIFAS SECTION -->
  <section class="pricing" id="tarifas">
    <div class="container">
      <div class="section-heading reveal">
        <span>Nuestros Planes</span>
        <h2>Tarifas</h2>
        <p>Elige el plan que mejor se adapte a ti. Sin permanencia, sin compromiso.</p>
      </div>
      <div class="pricing-grid">

        <!-- Basic -->
        <div class="pricing-card reveal">
          <img src="/icons/running.svg" alt="Icono plan básico" class="pricing-icon" />
          <h3 class="pricing-name">Básico</h3>
          <p class="pricing-desc">Ideal para empezar tu rutina</p>
          <div class="pricing-price">
            <span class="amount">29€</span>
            <span class="period">/mes</span>
          </div>
          <ul class="pricing-features">
            <li>Acceso a sala de musculación</li>
            <li>Zona de cardio</li>
            <li>Vestuarios y duchas</li>
            <li>Horario completo</li>
            <li class="disabled">Clases dirigidas</li>
            <li class="disabled">Entrenador personal</li>
            <li class="disabled">Zona spa y sauna</li>
          </ul>
          <a href="#contacto" class="btn-primary">Elegir Plan</a>
        </div>

        <!-- Premium -->
        <div class="pricing-card featured reveal">
          <div class="pricing-badge">Popular</div>
          <img src="/icons/muscle-flexing.svg" alt="Icono plan premium" class="pricing-icon" />
          <h3 class="pricing-name">Premium</h3>
          <p class="pricing-desc">El más completo para progresar</p>
          <div class="pricing-price">
            <span class="amount">49€</span>
            <span class="period">/mes</span>
          </div>
          <ul class="pricing-features">
            <li>Acceso a sala de musculación</li>
            <li>Zona de cardio</li>
            <li>Vestuarios y duchas</li>
            <li>Horario completo</li>
            <li>Clases dirigidas ilimitadas</li>
            <li>Evaluación mensual</li>
            <li class="disabled">Zona spa y sauna</li>
          </ul>
          <a href="#contacto" class="btn-primary">Elegir Plan</a>
        </div>

        <!-- VIP -->
        <div class="pricing-card reveal">
          <img src="/icons/personal-trainer.svg" alt="Icono plan VIP" class="pricing-icon" />
          <h3 class="pricing-name">VIP</h3>
          <p class="pricing-desc">La experiencia completa</p>
          <div class="pricing-price">
            <span class="amount">79€</span>
            <span class="period">/mes</span>
          </div>
          <ul class="pricing-features">
            <li>Acceso a sala de musculación</li>
            <li>Zona de cardio</li>
            <li>Vestuarios y duchas</li>
            <li>Horario completo</li>
            <li>Clases dirigidas ilimitadas</li>
            <li>Entrenador personal 2x/sem</li>
            <li>Zona spa y sauna</li>
          </ul>
          <a href="#contacto" class="btn-primary">Elegir Plan</a>
        </div>

      </div>
    </div>
  </section>

  <!-- GALERÍA SECTION -->
  <section class="gallery" id="galeria">
    <div class="container">
      <div class="section-heading reveal">
        <span>Nuestras Instalaciones</span>
        <h2>Galería</h2>
        <p>Descubre nuestro espacio diseñado para que entrenes al máximo nivel.</p>
      </div>
      <div class="gallery-grid">
        <div class="gallery-item reveal">
          <img src="/images/gallery-weights.png" alt="Zona de pesas y musculación" width="800" height="400" loading="lazy" />
          <div class="gallery-overlay">
            <h3>Zona de Pesas</h3>
          </div>
        </div>
        <div class="gallery-item reveal">
          <img src="/images/gallery-cardio.png" alt="Zona de cardio con cintas y bicicletas" width="400" height="250" loading="lazy" />
          <div class="gallery-overlay">
            <h3>Cardio</h3>
          </div>
        </div>
        <div class="gallery-item reveal">
          <img src="/images/gallery-boxing.png" alt="Zona de boxeo y artes marciales" width="400" height="250" loading="lazy" />
          <div class="gallery-overlay">
            <h3>Boxeo</h3>
          </div>
        </div>
        <div class="gallery-item reveal">
          <img src="/images/gallery-classes.png" alt="Sala de clases dirigidas" width="400" height="250" loading="lazy" />
          <div class="gallery-overlay">
            <h3>Clases Dirigidas</h3>
          </div>
        </div>
        <div class="gallery-item reveal">
          <img src="/images/gallery-training.png" alt="Zona de entrenamiento funcional" width="400" height="250" loading="lazy" />
          <div class="gallery-overlay">
            <h3>Funcional</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO SECTION -->
  <section class="contact" id="contacto">
    <div class="container">
      <div class="section-heading reveal">
        <span>Hablemos</span>
        <h2>Contacto</h2>
        <p>¿Tienes alguna pregunta? Escríbenos y te responderemos lo antes posible.</p>
      </div>
      <div class="contact-grid">

        <!-- Info -->
        <div class="contact-info reveal">
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <h4>Dirección</h4>
              <p>Calle Principal 123<br/>28001 Madrid, España</p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <h4>Teléfono</h4>
              <p><a href="tel:+34912345678">+34 912 345 678</a></p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <h4>Email</h4>
              <p><a href="mailto:info@newfit.es">info@newfit.es</a></p>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div>
              <h4>Horario</h4>
              <p>Lunes a Viernes: 7:00 - 23:00<br/>Sábados: 8:00 - 21:00<br/>Domingos: 9:00 - 15:00</p>
            </div>
          </div>
        </div>

        <!-- Form -->
        <form class="contact-form reveal" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <input type="text" name="nombre" placeholder="Tu nombre" required id="input-name" />
            </div>
            <div class="form-group">
              <input type="email" name="email" placeholder="Tu email" required id="input-email" />
            </div>
          </div>
          <div class="form-group">
            <input type="text" name="asunto" placeholder="Asunto" id="input-subject" />
          </div>
          <div class="form-group">
            <textarea name="mensaje" placeholder="Tu mensaje" rows="5" required id="input-message"></textarea>
          </div>
          <button type="submit" class="btn-primary" id="btn-submit">Enviar Mensaje</button>
        </form>

      </div>

      <!-- Map -->
      <div class="contact-map reveal">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3037.223540218498!2d-3.7037902!3d40.4167754!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd42287d15c6beb1%3A0x1234567890abcdef!2sMadrid%2C%20Spain!5e0!3m2!1sen!2ses!4v1234567890"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación del gimnasio en Google Maps"
        ></iframe>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <a href="#hero" class="footer-logo">NEW<em>FIT</em></a>
      <p>© 2026 NewFit. Todos los derechos reservados.</p>
      <div class="footer-social">
        <a href="#" aria-label="Instagram" id="social-instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" aria-label="Facebook" id="social-facebook">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
        <a href="#" aria-label="Twitter / X" id="social-twitter">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </a>
      </div>
    </div>
  </footer>

</Layout>
