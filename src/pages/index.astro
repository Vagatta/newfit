  <script>
    const contactForm = document.getElementById('contact-form') as HTMLFormElement;
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const formData = new FormData(contactForm);
        const nombre = formData.get('nombre');
        const email = formData.get('email');
        const asunto = formData.get('asunto') || 'Sin asunto';
        const message = formData.get('mensaje');

        const text = `*Nueva consulta desde la web*\n\n*Nombre:* ${nombre}\n*Email:* ${email}\n*Asunto:* ${asunto}\n*Mensaje:* ${message}`;
        const encodedText = encodeURIComponent(text);
        const whatsappUrl = `https://api.whatsapp.com/send?phone=34633656503&text=${encodedText}`;

        window.open(whatsappUrl, '_blank');
      });
    }

    // Floating CTA functionality
    const floatingCtaTrigger = document.getElementById('floating-cta-trigger') as HTMLButtonElement;
    const floatingCtaPanel = document.getElementById('floating-cta-panel') as HTMLDivElement;
    const floatingCta = document.getElementById('floating-cta') as HTMLDivElement;

    if (floatingCtaTrigger && floatingCtaPanel && floatingCta) {
      floatingCtaTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        floatingCta.classList.toggle('active');
      });

      // Prevent panel clicks from closing
      floatingCtaPanel.addEventListener('click', (e) => {
        e.stopPropagation();
      });

      // Close when clicking outside
      document.addEventListener('click', (e) => {
        if (!floatingCta.contains(e.target as Node)) {
          floatingCta.classList.remove('active');
        }
      });
    }
  </script>
