---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Alta Trimestral SP - NEWFIT GYM">
  <div id="bridge-overlay">
    <div class="bridge-spinner"></div>
    <p>Cargando formulario de alta...</p>
    <p class="bridge-hint">Selecciona <strong>"CUOTA TRIMESTRAL SIN PERMANENCIA"</strong></p>
  </div>
  <iframe
    id="deporframe"
    src="https://deporweb.net/altaonline/nueva.aspx?header=false&footer=false&nav=false&lang=es-ES&type=TkVXRklUIEdZTXwzMDU="
    style="position:fixed;top:0;left:0;width:100%;height:100vh;border:none;z-index:9998;"
    allow="payment"
  ></iframe>

  <style>
    #bridge-overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100vh;
      background: #111;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      color: #fff;
      font-family: 'Inter', sans-serif;
      transition: opacity 0.5s ease;
    }
    #bridge-overlay.hidden {
      opacity: 0;
      pointer-events: none;
    }
    .bridge-spinner {
      width: 40px; height: 40px;
      border: 3px solid rgba(255,255,255,0.2);
      border-top-color: #e63946;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 1rem;
    }
    .bridge-hint {
      font-size: 0.85rem;
      opacity: 0.7;
      margin-top: 0.5rem;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
  </style>

  <script>
    const iframe = document.getElementById('deporframe');
    const overlay = document.getElementById('bridge-overlay');
    
    iframe.addEventListener('load', () => {
      // Hide overlay once iframe loads
      setTimeout(() => {
        overlay.classList.add('hidden');
        setTimeout(() => overlay.remove(), 600);
      }, 500);

      // Try to auto-click the Trimestral SP button (will only work if same-origin)
      try {
        const doc = iframe.contentDocument || iframe.contentWindow.document;
        // The 3rd plan (ctrl2) is "CUOTA TRIMESTRAL SIN PERMANENCIA"
        const btn = doc.querySelector('[id*="ctrl2"][id*="LinkButton_Seleccionar"]');
        if (btn) {
          btn.click();
        }
      } catch (e) {
        // Cross-origin - can't auto-click, user will see the plan list
        console.log('Cross-origin: user must manually select the plan');
      }
    });

    // Fallback: hide overlay after 5 seconds regardless
    setTimeout(() => {
      overlay.classList.add('hidden');
      setTimeout(() => overlay.remove(), 600);
    }, 5000);
  </script>
</Layout>
